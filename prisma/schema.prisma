// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum IncidentStatus {
  active
  closed
  verified
}

enum CheckpointStatus {
  open
  closed
  restricted
}

model Incident {
  id          Int            @id @default(autoincrement())
  type        String
  severity    Int
  description String
  latitude    Float
  longitude   Float
  status      IncidentStatus @default(active)
  createdAt   DateTime       @default(now())
}

model Checkpoint {
  id         Int                @id @default(autoincrement())
  name       String
  latitude   Float
  longitude  Float
  status     CheckpointStatus   @default(open)
  createdAt  DateTime           @default(now())
  histories  CheckpointHistory[]
}

model CheckpointHistory {
  id            Int               @id @default(autoincrement())
  checkpointId  Int
  status        CheckpointStatus
  createdAt     DateTime          @default(now())

  checkpoint Checkpoint @relation(fields: [checkpointId], references: [id], onDelete: Cascade)

  @@index([checkpointId])
}