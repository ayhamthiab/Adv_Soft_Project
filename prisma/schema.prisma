// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum IncidentStatus {
  active
  closed
  verified
}

enum CheckpointStatus {
  open
  closed
  restricted
}

enum ReportStatus {
  PENDING
  APPROVED
  REJECTED
}

enum VoteType {
  UP
  DOWN
}

model Incident {
  id          Int            @id @default(autoincrement())
  type        String
  severity    Int
  description String
  latitude    Float
  longitude   Float
  status      IncidentStatus @default(active)
  createdAt   DateTime       @default(now())
}

model Checkpoint {
  id         Int                @id @default(autoincrement())
  name       String
  latitude   Float
  longitude  Float
  status     CheckpointStatus   @default(open)
  createdAt  DateTime           @default(now())
  histories  CheckpointHistory[]
}

model CheckpointHistory {
  id            Int               @id @default(autoincrement())
  checkpointId  Int
  status        CheckpointStatus
  createdAt     DateTime          @default(now())

  checkpoint Checkpoint @relation(fields: [checkpointId], references: [id], onDelete: Cascade)

  @@index([checkpointId])
}

model Report {
  id          Int            @id @default(autoincrement())
  latitude    Float
  longitude   Float
  category    String
  description String
  status      ReportStatus   @default(PENDING)
  createdAt   DateTime       @default(now())

  audits ReportAudit[]
  votes  ReportVote[]
}

model ReportAudit {
  id       Int      @id @default(autoincrement())
  reportId Int
  action   String
  role     String
  createdAt DateTime @default(now())

  report Report @relation(fields: [reportId], references: [id])

  @@index([reportId])
}

model ReportVote {
  id       Int      @id @default(autoincrement())
  reportId Int
  voteType VoteType
  createdAt DateTime @default(now())

  report Report @relation(fields: [reportId], references: [id])

  @@index([reportId])
}

model AlertSubscription {
  id        Int      @id @default(autoincrement())
  latitude  Float
  longitude Float
  radius    Float
  category  String?
  createdAt DateTime @default(now())
}

model Alert {
  id             Int      @id @default(autoincrement())
  incidentId     Int
  subscriptionId Int
  createdAt      DateTime @default(now())

  @@index([incidentId])
  @@index([subscriptionId])
}